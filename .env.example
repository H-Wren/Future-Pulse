# Future Pulse Environment Variables

# Gemini API Key — required for local development
# Get one at: https://aistudio.google.com/apikey
# Supports both AIzaSy... (query-param) and AQ.... (Bearer) key formats
GEMINI_API_KEY=

# Set to "true" when deploying on Vercel to proxy API calls
# through the serverless function at /api/gemini
# VITE_USE_SERVER_API=true
