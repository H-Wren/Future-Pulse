# Future Pulse Environment Variables
# ==========================================
# Copy this file to .env.local and fill in your keys

# --- DeepSeek API Key (primary provider, works in China without VPN) ---
# Get one at: https://platform.deepseek.com/ → API Keys
DEEPSEEK_API_KEY=

# --- Gemini API Key (alternative provider) ---
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Server API mode (for Vercel deployment) ---
# Set to "true" to proxy API calls through Vercel serverless functions
# VITE_USE_SERVER_API=true

# --- Public mode (for GitHub Pages deployment) ---
# Set to your Cloudflare Worker URL to enable public mode
# Public mode hides API key UI and routes all requests through the worker
# VITE_WORKER_URL=https://future-pulse.hsw05859.workers.dev
